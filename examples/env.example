# agentic-wallet-mcp — environment variable template.
# Copy to your MCP client's env block (or a .env you load yourself) and fill the placeholders.
# Do NOT commit a filled-in copy with real secrets.

# --- Required ---
# Zetrix network: zetrix:testnet | zetrix:mainnet
ZETRIX_NETWORK=zetrix:testnet
# HSM password (sensitive — never logged). Prefer a secret manager over an inline value.
HSM_PASSWORD=<your-hsm-password>

# --- Holder identity (optional) ---
# Omit both on first run: the MCP creates a new HSM account at startup and logs the
# address/DID to stderr — copy them back in for next time.
# ZETRIX_ADDRESS=<ZTX3...>
# HOLDER_DID=<did:zid:...>   # optional even with ZETRIX_ADDRESS set — derived from the account key

# --- Service URL overrides (optional) ---
# Leave unset to use the built-in default for the chosen ZETRIX_NETWORK.
# Set these only if you run your own instance of the service.
# WALLET_BE_URL=<https://your-wallet-be/server>
# MBI_BASE_URL=<https://your-mbi-rs>
# OID4VP_BASE_URL=<https://your-oid4vp-verifier/api>
# ZID_RESOLVER_BASE_URL=<https://your-zid-resolver>
# ZETRIX_NODE_HOST=<rpc-node-host>
# ZETRIX_NODE_PORT=<rpc-node-port>

# --- Payment cap (strongly recommended before mainnet / real funds) ---
# Per-asset x402 auto-pay ceiling. JSON: asset -> max raw-unit string, "*" = fallback.
# Once set it acts as an allowlist: an asset with no entry and no "*" fallback is denied.
# MAX_PAYMENT_AMOUNT={"ZTX":"1000000000","*":"0"}
